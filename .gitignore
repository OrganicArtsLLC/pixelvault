# Pixel Vault — .gitignore
# ─────────────────────────────────────────────────────────────────

# ── Secrets & credentials (never commit) ──
.env
.env.*
*.key
*.pem
*.cert
*.p12
*.pfx
secrets/
.secrets/

# ── Publish system (sensitive — config contains S3 bucket + API URL) ──
publish-config.json
config.json

# ── Infrastructure secrets ──
infra/.env
infra/.aws-sam/
infra/samconfig.toml
infra/__pycache__/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.pyc
venv/
.venv/
*.egg-info/

# ── Node ──
node_modules/
dist/
.npm/

# ── macOS ──
.DS_Store
.AppleDouble
.LSOverride

# ── Editor artifacts ──
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Test / tmp ──
/tmp/
*.tmp
test-output/

# ── Build outputs ──
/build/
/out/

# ── Generated QA artifacts ──
qa-report.json

# ============================================================
# PRIVATE CONTENT — Not tracked in public repository
# ============================================================
# ⚠️  WARNING: All game directories are DEFAULT PRIVATE.
#     To publish a game, run: tools/publish-game.sh <file>
#     which uses `git add -f` to force-track it.
#
#     DO NOT remove these rules without reviewing ADR-019.
#     The pre-commit hook enforces this boundary.
# ============================================================

# --- All game directories (default-private, publish individually) ---
prototypes/
ai-archaeology/
ai-evolution/

# --- Agent instructions (private workflow, not for public) ---
CLAUDE.md
.github/copilot-instructions.md

# --- Internal research (IP sensitivity) ---
docs/IP-WATCHLIST.md

# ── Staging build artifacts ──
.staging/
public/config/monetization-config.local.json
