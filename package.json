{
  "name": "pixelvault",
  "version": "0.9.0",
  "description": "Pixel Vault — Museum of game mechanics & AI history",
  "private": true,
  "scripts": {
    "serve": "python3 -m http.server 8080",
    "thumbnails": "node tools/generate-thumbnails.js",
    "thumbnails:dry": "node tools/generate-thumbnails.js --dry-run",
    "thumbnails:test": "node tools/generate-thumbnails.js --limit=10",
    "catalogue": "python3 tools/catalogue-generator.py",
    "qa": "node tools/qa-pass1.js",
    "qa:security": "node tools/qa-security.js",
    "test": "bash tools/test-games.sh"
  },
  "devDependencies": {
    "playwright": "^1.42.0",
    "sharp": "^0.33.2"
  }
}
